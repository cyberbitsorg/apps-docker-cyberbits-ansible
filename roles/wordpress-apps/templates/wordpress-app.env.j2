WP_LOGGED_IN_KEY={{ lookup('vars', item.name + '_wp_logged_in_key') }}
WP_NONCE_KEY={{ lookup('vars', item.name + '_wp_nonce_key') }}
WP_AUTH_SALT={{ lookup('vars', item.name + '_wp_auth_salt') }}
WP_SECURE_AUTH_SALT={{ lookup('vars', item.name + '_wp_secure_auth_salt') }}
WP_LOGGED_IN_SALT={{ lookup('vars', item.name + '_wp_logged_in_salt') }}
WP_NONCE_SALT={{ lookup('vars', item.name + '_wp_nonce_salt') }}
