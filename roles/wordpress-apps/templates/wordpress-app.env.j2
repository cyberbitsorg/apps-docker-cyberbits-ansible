# Database
DB_ROOT_PASSWORD={{ lookup('vars', item.name + '_mysql_root_password', default=lookup('password', '/dev/null length=32 chars=ascii_letters,digits')) }}
DB_NAME={{ item.db_name | default('wordpress') }}
DB_USER={{ item.db_user | default('wordpress') }}
DB_PASSWORD={{ lookup('vars', item.name + '_mysql_password', default=lookup('password', '/dev/null length=32 chars=ascii_letters,digits')) }}

# WordPress Table Prefix
WP_TABLE_PREFIX={{ item.table_prefix | default('wp_') }}

# WordPress Keys
WP_AUTH_KEY={{ lookup('vars', item.name + '_wp_auth_key', default=lookup('password', '/dev/null length=32 chars=ascii_letters,digits')) }}
WP_SECURE_AUTH_KEY={{ lookup('vars', item.name + '_wp_secure_auth_key', default=lookup('password', '/dev/null length=32 chars=ascii_letters,digits')) }}
WP_LOGGED_IN_KEY={{ lookup('vars', item.name + '_wp_logged_in_key', default=lookup('password', '/dev/null length=32 chars=ascii_letters,digits')) }}
WP_NONCE_KEY={{ lookup('vars', item.name + '_wp_nonce_key', default=lookup('password', '/dev/null length=32 chars=ascii_letters,digits')) }}
WP_AUTH_SALT={{ lookup('vars', item.name + '_wp_auth_salt', default=lookup('password', '/dev/null length=32 chars=ascii_letters,digits')) }}
WP_SECURE_AUTH_SALT={{ lookup('vars', item.name + '_wp_secure_auth_salt', default=lookup('password', '/dev/null length=32 chars=ascii_letters,digits')) }}
WP_LOGGED_IN_SALT={{ lookup('vars', item.name + '_wp_logged_in_salt', default=lookup('password', '/dev/null length=32 chars=ascii_letters,digits')) }}
WP_NONCE_SALT={{ lookup('vars', item.name + '_wp_nonce_salt', default=lookup('password', '/dev/null length=32 chars=ascii_letters,digits')) }}
