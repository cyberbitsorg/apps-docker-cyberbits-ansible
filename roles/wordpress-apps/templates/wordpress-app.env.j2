# Database
DB_ROOT_PASSWORD={{ lookup('vars', item.name + '_mysql_root_password') }}
DB_NAME={{ item.db_name | default('wordpress') }}
DB_USER={{ item.db_user | default('wordpress') }}
DB_PASSWORD={{ lookup('vars', item.name + '_mysql_password') }}

# WordPress Table Prefix
WP_TABLE_PREFIX={{ item.table_prefix | default('wp_') }}

# WordPress Keys
WP_AUTH_KEY={{ lookup('vars', item.name + '_wp_auth_key') }}
