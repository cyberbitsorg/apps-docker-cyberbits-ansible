<!DOCTYPE html>
<html>
<head>
    <title>{{ item.title | default(item.domain) }}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 800px;
            margin: 50px auto;
            padding: 20px;
            text-align: center;
        }
        h1 { color: #333; }
        p { color: #666; }
    </style>
</head>
<body>
    <h1>{{ item.title | default(item.domain) }}</h1>
    <p>{{ item.message | default('Website deployed with Ansible + Docker') }}</p>
    <hr>
    <p><small>Domain: {{ item.domain }}</small></p>
</body>
</html>
