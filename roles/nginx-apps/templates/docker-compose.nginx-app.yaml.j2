services:
  {{ item.name }}:
    image: nginx:alpine
    container_name: "nx-{{ item.name }}"
    restart: unless-stopped
    volumes:
      - ./data:/var/www/html:ro
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - /etc/localtime:/etc/localtime:ro
    networks:
      - traefik
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://127.0.0.1/nginx-health"]
      interval: 30s
      timeout: 5s
      retries: 3
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.nx-{{ item.name }}.rule=Host(`{{ item.domain }}`){% if item.www_redirect | default(false) %} || Host(`www.{{ item.domain }}`){% endif %}"
      - "traefik.http.routers.nx-{{ item.name }}.entrypoints=websecure"
      - "traefik.http.routers.nx-{{ item.name }}.tls=true"
      - "traefik.http.routers.nx-{{ item.name }}.tls.certresolver=letsencrypt"
      - "traefik.http.routers.nx-{{ item.name }}.middlewares=security-headers@file,rate-limit@file,compress@file"
      - "traefik.http.services.nx-{{ item.name }}.loadbalancer.server.port=80"

networks:
  traefik:
    external: true
